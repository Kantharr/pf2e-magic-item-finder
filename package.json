{
  "name": "pf2e-magic-item-finder",
  "version": "1.0.0",
  "description": "FoundryVTT (PF2e) module: search magic items by ability tag.",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vite build",
    "watch": "vite build --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "deploy": "npm run build && node scripts/deploy.mjs"
  },
  "dependencies": {
    "minisearch": "^7.1.0"
  },
  "devDependencies": {
    "fvtt-types": "13.346.0-beta.20250812191140",
    "typescript": "^5.6.0",
    "vite": "^6.3.0",
    "vite-plugin-static-copy": "^2.2.0",
    "vitest": "^4.1.10"
  }
}
